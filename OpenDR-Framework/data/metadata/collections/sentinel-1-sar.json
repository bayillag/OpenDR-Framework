      "roles": ["producer", "licensor"],
      "url": "https://sentinel.esa.int/web/sentinel/missions/sentinel-1"
    },
    {
      "name": "Jinka Regional Veterinary Laboratory",
      "roles": ["processor", "host"],
      "url": "https://github.com/bayillag/OpenDR-Framework"
    }
  ],
  "extent": {
    "spatial": {
      "bbox": [
        [33.0, 3.0, 48.0, 15.0]
      ]
    },
